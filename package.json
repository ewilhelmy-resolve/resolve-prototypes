{
  "name": "resolve-onboarding",
  "version": "1.0.0",
  "description": "Resolve onboarding POC with Stripe integration",
  "scripts": {
    "start": "node server-enhanced.js",
    "dev": "nodemon --watch . --ext js,html,css --ignore node_modules/ --ignore data/ server-enhanced.js",
    "docker:up": "docker-compose up -d",
    "docker:dev": "BUILD_TARGET=development DEV_MOUNT=.:/app docker-compose up",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose build --no-cache",
    "docker:frontend": "docker-compose --profile frontend up -d",
    "docker:clean": "docker-compose down -v && docker system prune -f",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "db:init": "node init-db.js",
    "db:migrate": "node migrate-to-postgres.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "eventsource": "^4.0.0",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.5",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.0.2",
    "pg": "^8.11.3",
    "sqlite3": "^5.1.7"
  },
  "main": "playwright.config.js",
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resolve-io/resolve-onboarding.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/resolve-io/resolve-onboarding/issues"
  },
  "homepage": "https://github.com/resolve-io/resolve-onboarding#readme"
}
