{
  "name": "rita-api-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --apply .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --apply .",
    "migrate": "dotenv -e ../../.env -- tsx src/database/migrate.ts",
    "test:auth": "dotenv -e ../../.env -- tsx src/scripts/test-auth.ts",
    "tail-logs": "dotenv -e ../../.env -- tsx src/scripts/tail-logs.ts"
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "@types/pino-http": "^5.8.4",
    "amqplib": "^0.10.9",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.18.0",
    "jose": "^6.1.0",
    "multer": "^2.0.2",
    "pg": "^8.11.0",
    "pino": "^9.9.5",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.1",
    "pino-roll": "^3.1.0",
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/amqplib": "^0.10.7",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "dotenv-cli": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.2.2"
  }
}
