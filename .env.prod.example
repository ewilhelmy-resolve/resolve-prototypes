# Production Environment Configuration
# Copy this file to .env.prod and fill in your actual values

# Database Configuration (Managed Service)
DATABASE_URL=postgresql://username:password@your-db-host:5432/database_name

# Message Queue (Managed Service)
RABBITMQ_URL=amqp://username:password@your-rabbitmq-host:5672

# Session Store (Managed Service)
REDIS_URL=redis://username:password@your-redis-host:6379

# Keycloak Configuration (Managed Service)
KEYCLOAK_URL=https://your-keycloak-domain.com
KEYCLOAK_REALM=rita-chat-realm
KEYCLOAK_CLIENT_ID=rita-chat-client
# Optional: Override JWT issuer validation (usually not needed in production)
# KEYCLOAK_ISSUER=https://your-keycloak-domain.com/realms/rita-chat-realm


# External Service (Mock)
AUTOMATION_WEBHOOK_URL=https://external_service/webhook
AUTOMATION_AUTH=secret-token

# Application Configuration
CLIENT_URL=https://yourapp.com
PORT=80

# Optional: If using a reverse proxy or load balancer
# EXTERNAL_PORT=80
# EXTERNAL_HTTPS_PORT=443
