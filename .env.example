# =================================================================
# RESOLVE ONBOARDING APPLICATION - ENVIRONMENT VARIABLES
# =================================================================
# 
# SECURITY NOTICE: 
# - Never commit actual values to version control
# - Use strong, unique values for all secrets
# - Rotate secrets regularly in production
# - Use a secrets management service in production (AWS Secrets Manager, Azure Key Vault, etc.)

# =================================================================
# SERVER CONFIGURATION
# =================================================================

# Environment (development, staging, production)
NODE_ENV=production

# Server port
PORT=5000

# Application URL (used for webhooks and redirects)
APP_URL=https://your-domain.com

# =================================================================
# DATABASE CONFIGURATION
# =================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://username:password@hostname:port/database

# Database connection pool settings
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# =================================================================
# SECURITY SECRETS (CRITICAL - GENERATE STRONG RANDOM VALUES)
# =================================================================

# JWT Secret (minimum 32 characters, use: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars

# Session Secret (minimum 32 characters, use: openssl rand -base64 32)
SESSION_SECRET=your-super-secret-session-key-minimum-32-chars

# Session timeout in milliseconds (default: 24 hours)
SESSION_TIMEOUT=86400000

# Password hashing rounds (10-12 recommended)
BCRYPT_ROUNDS=12

# Admin email addresses (comma-separated)
ADMIN_EMAILS=admin@your-company.com,admin2@your-company.com

# =================================================================
# RATE LIMITING & SECURITY
# =================================================================

# Rate limiting window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW=900000

# Max requests per window
RATE_LIMIT_MAX=100

# Auth-specific rate limit (stricter)
AUTH_RATE_LIMIT_MAX=5

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# =================================================================
# FILE UPLOAD CONFIGURATION
# =================================================================

# Upload directory path
UPLOAD_DIR=./uploads

# Maximum file size in bytes (default: 50MB)
MAX_FILE_SIZE=52428800

# Maximum request body size
MAX_REQUEST_SIZE=100mb

# Use S3 for file storage (true/false)
USE_S3=false

# S3 bucket name (if USE_S3=true)
S3_BUCKET=your-s3-bucket-name

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=csv,txt,pdf,zip,json,docx,xlsx

# =================================================================
# WEBHOOK & AUTOMATION CONFIGURATION
# =================================================================

# Enable webhooks (true/false)
WEBHOOK_ENABLED=true

# Webhooks feature flag
WEBHOOKS_ENABLED=true

# Automation webhook URL
AUTOMATION_WEBHOOK_URL=https://your-automation-service.com/webhook

# Automation service authentication header
AUTOMATION_AUTH=Basic your-encoded-auth-string

# Webhook retry settings
WEBHOOK_RETRY_INTERVAL=60000
WEBHOOK_MAX_RETRIES=3

# =================================================================
# RAG (Retrieval-Augmented Generation) CONFIGURATION
# =================================================================

# Enable RAG features (true/false)
RAG_ENABLED=true

# Maximum document size for RAG processing (bytes)
MAX_DOCUMENT_SIZE=51200

# Vector embedding dimension (OpenAI: 1536)
VECTOR_DIMENSION=1536

# OpenAI embedding model
EMBEDDING_MODEL=text-embedding-ada-002

# Search results limit
RAG_SEARCH_LIMIT=10

# OpenAI API Key (if using OpenAI for embeddings)
OPENAI_API_KEY=your-openai-api-key

# =================================================================
# MONITORING & LOGGING
# =================================================================

# Sentry DSN for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable request logging (true/false)
ENABLE_REQUEST_LOGGING=false

# Webhook traffic retention in days
WEBHOOK_TRAFFIC_RETENTION_DAYS=7

# =================================================================
# FEATURE FLAGS
# =================================================================

# Enable/disable major features
ADMIN_PANEL_ENABLED=true
USER_REGISTRATION_ENABLED=true

# =================================================================
# SESSION & CLEANUP CONFIGURATION
# =================================================================

# Session cleanup interval (milliseconds, default: 1 hour)
SESSION_CLEANUP_INTERVAL=3600000

# Expired sessions cleanup threshold (days)
EXPIRED_SESSIONS_CLEANUP_DAYS=30

# =================================================================
# SMTP CONFIGURATION (for password reset emails)
# =================================================================

# SMTP server settings
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Email sender information
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Your Application Name

# =================================================================
# REDIS CONFIGURATION (for session storage in production)
# =================================================================

# Redis connection URL (optional, for session storage)
REDIS_URL=redis://username:password@hostname:port

# Redis session store settings
REDIS_SESSION_PREFIX=sess:
REDIS_SESSION_TTL=86400

# =================================================================
# SSL/TLS CONFIGURATION
# =================================================================

# Force HTTPS redirects (true/false)
FORCE_HTTPS=true

# SSL certificate paths (if serving HTTPS directly)
SSL_KEY_PATH=/path/to/private-key.pem
SSL_CERT_PATH=/path/to/certificate.pem

# =================================================================
# BACKUP & MAINTENANCE
# =================================================================

# Database backup schedule (cron format)
DB_BACKUP_SCHEDULE=0 2 * * *

# Backup retention days
BACKUP_RETENTION_DAYS=30

# Maintenance mode (true/false)
MAINTENANCE_MODE=false

# =================================================================
# DEVELOPMENT OVERRIDES
# =================================================================
# These settings override production defaults in development

# Development database (optional override)
# DEV_DATABASE_URL=postgresql://dev_user:dev_pass@localhost:5432/dev_db

# Skip email verification in development
# DEV_SKIP_EMAIL_VERIFICATION=true

# Allow weak passwords in development (NOT recommended)
# DEV_ALLOW_WEAK_PASSWORDS=false

# =================================================================
# SECRETS GENERATION COMMANDS
# =================================================================
# 
# Use these commands to generate secure secrets:
# 
# JWT_SECRET:     openssl rand -base64 48
# SESSION_SECRET: openssl rand -base64 48
# API_KEY:        openssl rand -hex 32
# 
# Password for databases/services:
# openssl rand -base64 32
# 
# =================================================================