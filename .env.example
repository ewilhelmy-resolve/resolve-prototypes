# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://rita:rita@localhost:5432/rita

# External Service
AUTOMATION_WEBHOOK_URL=https://external-service.com/webhook
AUTOMATION_AUTH=your-secret-token

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
QUEUE_NAME=rita_responses

# Redis (for SSE scaling)
REDIS_URL=redis://localhost:6379

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=rita-chat-realm

# Client Environment (VITE_ prefixed)
VITE_API_URL=http://localhost:3000
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=rita-chat-realm
VITE_KEYCLOAK_CLIENT_ID=rita-chat-client