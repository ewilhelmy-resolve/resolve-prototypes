{
	"permissions": {
		"allow": [
			"Bash(npm run type-check:*)",
			"Bash(npm test:*)",
			"mcp__figma__get_design_context",
			"mcp__figma__get_variable_defs",
			"mcp__figma__get_screenshot",
			"mcp__figma__get_metadata"
		],
		"deny": [],
		"ask": []
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash(git commit*)",
				"hooks": [
					{
						"type": "command",
						"command": "pnpm run lint"
					}
				]
			}
		]
	}
}
