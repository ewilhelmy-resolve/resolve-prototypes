{
	"permissions": {
		"allow": [
			"Bash(npm run type-check:*)",
			"Bash(npm test:*)",
			"mcp__figma__get_design_context",
			"mcp__figma__get_variable_defs",
			"mcp__figma__get_screenshot",
			"mcp__figma__get_metadata"
		],
		"deny": [],
		"ask": []
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash(git commit*)",
				"hooks": [
					{
						"type": "command",
						"command": "pnpm run lint"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "cd \"$CLAUDE_PROJECT_DIR\" && pnpm run type-check && if echo \"$TOOL_INPUT\" | grep -qE 'packages/api-server/src/(routes|schemas|docs)/'; then pnpm --filter rita-api-server docs:generate; fi"
					}
				]
			}
		]
	}
}
