{
	"root": "login-container",
	"elements": {
		"login-container": {
			"type": "Card",
			"props": {
				"title": "Login",
				"description": "Enter your credentials to access your account",
				"maxWidth": "sm",
				"centered": true
			},
			"children": ["form-stack"]
		},
		"form-stack": {
			"type": "Stack",
			"props": {
				"direction": "vertical",
				"gap": "md"
			},
			"children": [
				"username-input",
				"password-input",
				"button-group",
				"signup-section"
			]
		},
		"username-input": {
			"type": "Input",
			"props": {
				"label": "Username",
				"name": "username",
				"placeholder": "Enter your username",
				"value": {
					"$bindState": "/form/username"
				},
				"checks": [
					{
						"type": "required",
						"message": "Username is required"
					},
					{
						"type": "minLength",
						"message": "Username must be at least 6 characters",
						"args": {
							"min": 6
						}
					}
				]
			},
			"children": []
		},
		"password-input": {
			"type": "Input",
			"props": {
				"label": "Password",
				"name": "password",
				"type": "password",
				"placeholder": "Enter your password",
				"value": {
					"$bindState": "/form/password"
				},
				"checks": [
					{
						"type": "required",
						"message": "Password is required"
					},
					{
						"type": "minLength",
						"message": "Password must be at least 6 characters",
						"args": {
							"min": 6
						}
					}
				]
			},
			"children": []
		},
		"button-group": {
			"type": "Stack",
			"props": {
				"direction": "horizontal",
				"gap": "md",
				"justify": "center"
			},
			"children": ["send-button", "clear-button"]
		},
		"send-button": {
			"type": "Button",
			"props": {
				"label": "Send",
				"variant": "primary"
			},
			"on": {
				"press": {
					"action": "buttonClick",
					"params": {
						"message": "Login successful!"
					}
				}
			},
			"children": []
		},
		"clear-button": {
			"type": "Button",
			"props": {
				"label": "Clear",
				"variant": "secondary"
			},
			"on": {
				"press": {
					"action": "setState",
					"params": {
						"statePath": "/form",
						"value": {
							"username": "",
							"password": ""
						}
					}
				}
			},
			"children": []
		},
		"signup-link": {
			"type": "Stack",
			"props": {
				"direction": "horizontal",
				"gap": "sm",
				"justify": "center"
			},
			"children": ["signup-text", "signup-button"]
		},
		"signup-text": {
			"type": "Text",
			"props": {
				"text": "Don't have an account?",
				"variant": "body"
			},
			"children": []
		},
		"signup-button": {
			"type": "Link",
			"props": {
				"label": "Sign up here",
				"href": "/signup"
			},
			"on": {
				"press": {
					"action": "linkClick",
					"params": {
						"message": "Navigating to sign up page"
					}
				}
			},
			"children": []
		},
		"signup-section": {
			"type": "Stack",
			"props": {
				"direction": "horizontal",
				"gap": "sm",
				"justify": "center"
			},
			"children": ["signup-text", "signup-button"]
		}
	},
	"state": {
		"form": {
			"username": "",
			"password": ""
		}
	}
}
